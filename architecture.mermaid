---
title: NumNum Workout — Complete Architecture (Post Phase 1)
---
graph TB
    %% ============================================================
    %% CLIENTS
    %% ============================================================
    subgraph CLIENTS["👤 Clients"]
        direction TB
        BROWSER["🌐 Athlete App<br/><b>index.html</b><br/>Single-page PWA<br/>3,240 lines HTML/CSS/JS"]
        ADMIN["📊 Coach Dashboard<br/><b>admin.py</b> (Streamlit)<br/>localhost:8501<br/>Programs · Users · Athletes · Exercises"]
    end

    %% ============================================================
    %% FASTAPI SERVER
    %% ============================================================
    subgraph SERVER["⚡ FastAPI Server — run.py → app/main.py (localhost:5050)"]
        direction TB

        subgraph MIDDLEWARE["Middleware Layer"]
            CORS["CORS<br/>Origins: localhost:5050,<br/>127.0.0.1:5050, numnum.fit"]
            STATIC["StaticFiles Mount<br/>Serves: index.html, program.json,<br/>exercises.json, privacy.html, *.svg"]
        end

        subgraph AUTH_LAYER["Authentication Layer — app/auth.py"]
            JWT_CREATE["JWT Creation<br/>Access: 15 min<br/>Refresh: 7 days<br/>Algorithm: HS256"]
            JWT_VALIDATE["JWT Validation<br/>get_current_user()<br/>require_coach()<br/>get_optional_user()"]
            PWD["Password Hashing<br/>bcrypt (primary)<br/>SHA256 → bcrypt migration"]
        end

        subgraph ROUTES["API Routes"]
            direction TB

            subgraph AUTH_ROUTES["🔐 Auth Routes — /api/auth/*<br/>No JWT required"]
                LOGIN["POST /login<br/>{email, password}<br/>→ {access_token, refresh_token,<br/>user_name, role}"]
                REFRESH["POST /refresh<br/>{refresh_token}<br/>→ {access_token}"]
                FORGOT["POST /forgot-password<br/>{email} → reset email"]
                RESET["POST /reset-password<br/>{token, new_password}"]
            end

            subgraph WORKOUT_ROUTES["💪 Workout Routes — /api/*<br/>JWT required"]
                GET_DATA["GET /data<br/>→ {workout_logs, whoop_snapshots,<br/>notes, metrics}"]
                SAVE_DAY["POST /save-day<br/>{day_key, data, meta}"]
                SYNC_ALL["POST /sync-all<br/>{days} → bulk sync"]
                SAVE_WHOOP["POST /save-whoop<br/>{snapshot} → keeps last 90"]
            end

            subgraph METRICS_ROUTES["📏 Metrics Routes — /api/*<br/>JWT required"]
                GET_METRICS["GET /metrics<br/>→ {entries}"]
                SAVE_METRICS["POST /save-metrics<br/>{date, weight_kg,<br/>body_fat_pct, ...}"]
            end

            subgraph COACH_ROUTES["🏋️ Coach Routes — /api/coach/*<br/>JWT + Coach role"]
                LIST_USERS["GET /users<br/>→ [{user, workout_logs,<br/>whoop_snapshots, latest_log}]"]
                GET_USER["GET /user/{username}<br/>→ full athlete data"]
            end

            subgraph VERIFY_ROUTES["✉️ Verify Routes — /api/*<br/>No JWT required"]
                SEND_VERIFY["POST /send-verification<br/>{email, user} → 6-digit code"]
                DO_VERIFY["POST /verify-email<br/>{email, code, user}"]
            end

            subgraph WHOOP_ROUTES["⌚ Whoop Routes — /whoop/*"]
                WHOOP_AUTH["GET /auth (JWT)<br/>→ {auth_url}"]
                WHOOP_CB["GET /callback (public)<br/>OAuth redirect handler"]
                WHOOP_STATUS["GET /status (public)<br/>→ {connected}"]
                WHOOP_DISC["GET /disconnect (JWT)"]
                WHOOP_SUMMARY["GET /summary (JWT)<br/>→ {recovery, strain, sleep}"]
                WHOOP_DETAIL["GET /recovery, /sleep,<br/>/strain, /workout (JWT)"]
            end

            HEALTH["GET /api/health<br/>→ {status, version}"]
        end

        subgraph CORE["Core Modules"]
            CONFIG["app/config.py<br/>PORT, SECRET_KEY, CORS_ORIGINS,<br/>SMTP_*, WHOOP_*, ENCRYPTION_KEY,<br/>file paths"]
            DATA["app/data.py<br/>load_users() · save_users()<br/>load_user_data() · save_user_data()<br/>find_user_by_email()"]
            ENCRYPT["app/encryption.py<br/>Fernet encrypt/decrypt<br/>migrate_tokens_file()"]
            MODELS["app/models.py<br/>LoginRequest · LoginResponse<br/>SaveDayRequest · MetricEntry<br/>+ 8 more Pydantic models"]
        end
    end

    %% ============================================================
    %% DATA STORAGE
    %% ============================================================
    subgraph STORAGE["💾 Data Storage (JSON Files on Disk)"]
        direction TB
        USERS_JSON["users.json<br/>──────────────<br/>3 users: Juan (coach),<br/>Jack (athlete), Caroline (athlete)<br/>Fields: program, startDate, email,<br/>passwordHash (bcrypt), role,<br/>email_verified"]
        USER_DATA["user_data/*.json<br/>──────────────<br/>Per-user files (e.g. Juan.json)<br/>• workout_logs: {day_N: {data, meta, saved_at}}<br/>• whoop_snapshots: [{recovery, sleep, ...}]<br/>• notes: {}<br/>• metrics: [{date, weight_kg, ...}]"]
        PROGRAM_JSON["program.json (532 KB)<br/>──────────────<br/>All workout programs<br/>programs → weeks → days →<br/>exerciseGroups → exercises<br/>(sets, reps, tempo, rest, RPE)"]
        EXERCISES_JSON["exercises.json (11 KB)<br/>──────────────<br/>Exercise database by muscle group<br/>Chest · Back · Shoulders ·<br/>Legs · Arms · Core"]
        PROGRAM_CSV["program.csv (127 KB)<br/>──────────────<br/>Source of truth for programs<br/>Editable via Streamlit admin"]
        WHOOP_TOKENS["whoop_tokens.json<br/>──────────────<br/>Fernet-encrypted tokens<br/>{user: {access_token,<br/>refresh_token, expires_at}}"]
        WHOOP_CONFIG["whoop_config.json<br/>──────────────<br/>client_id, client_secret,<br/>redirect_uri"]
    end

    %% ============================================================
    %% EXTERNAL SERVICES
    %% ============================================================
    subgraph EXTERNAL["🌍 External Services"]
        WHOOP_API["Whoop API<br/>api.prod.whoop.com<br/>──────────────<br/>OAuth2 Authorization<br/>/v2/recovery<br/>/v2/activity/sleep<br/>/v2/cycle<br/>/v2/activity/workout"]
        SMTP["SMTP Email<br/>smtp.gmail.com:587<br/>──────────────<br/>Verification codes<br/>Password reset links"]
    end

    %% ============================================================
    %% IN-MEMORY STATE
    %% ============================================================
    subgraph MEMORY["🧠 In-Memory State (Lost on Restart)"]
        VERIFY_CODES["VERIFICATION_CODES<br/>{email: {code, expires, user}}"]
        RESET_TOKENS["RESET_TOKENS<br/>{token: {email, user, expires}}"]
        PENDING_AUTH["pending_auth<br/>{state: {user_key, created_at}}"]
    end

    %% ============================================================
    %% DEPLOYMENT
    %% ============================================================
    subgraph DEPLOY["🚀 Deployment Config"]
        PROCFILE["Procfile<br/>web: python run.py"]
        NIXPACKS["nixpacks.toml<br/>python311 · python run.py"]
        RUNTIME["runtime.txt<br/>python-3.11.x"]
        REQUIREMENTS["requirements.txt<br/>fastapi · uvicorn · python-jose<br/>passlib · bcrypt · slowapi<br/>python-multipart · cryptography"]
    end

    %% ============================================================
    %% CONNECTIONS — Browser to Server
    %% ============================================================
    BROWSER -->|"POST /api/auth/login<br/>{email, password}"| LOGIN
    BROWSER -->|"POST /api/auth/refresh<br/>{refresh_token}"| REFRESH
    BROWSER -->|"authFetch() — Bearer JWT<br/>GET /api/data"| GET_DATA
    BROWSER -->|"authFetch()<br/>POST /api/save-day"| SAVE_DAY
    BROWSER -->|"authFetch()<br/>POST /api/sync-all"| SYNC_ALL
    BROWSER -->|"authFetch()<br/>POST /api/save-whoop"| SAVE_WHOOP
    BROWSER -->|"authFetch()<br/>GET & POST /api/metrics"| GET_METRICS
    BROWSER -->|"POST /api/send-verification<br/>POST /api/verify-email"| SEND_VERIFY
    BROWSER -->|"authFetch()<br/>GET /whoop/*"| WHOOP_AUTH
    BROWSER -->|"GET / (static)"| STATIC

    %% ============================================================
    %% CONNECTIONS — Admin to Data
    %% ============================================================
    ADMIN -->|"Direct file read<br/>user_data/*.json"| USER_DATA
    ADMIN -->|"Read/Write<br/>program.csv ↔ program.json"| PROGRAM_CSV
    ADMIN -->|"Read/Write"| PROGRAM_JSON
    ADMIN -->|"Read/Write"| USERS_JSON
    ADMIN -->|"Read/Write"| EXERCISES_JSON

    %% ============================================================
    %% CONNECTIONS — Server to Data
    %% ============================================================
    AUTH_LAYER -->|"Read/Write"| USERS_JSON
    DATA -->|"Read/Write"| USER_DATA
    DATA -->|"Read/Write"| USERS_JSON
    ENCRYPT -->|"Read/Write"| WHOOP_TOKENS

    %% ============================================================
    %% CONNECTIONS — Server to External
    %% ============================================================
    WHOOP_ROUTES -->|"OAuth2 + REST API<br/>Bearer token"| WHOOP_API
    WHOOP_ROUTES -->|"Read config"| WHOOP_CONFIG
    VERIFY_ROUTES -->|"Send code email"| SMTP
    AUTH_ROUTES -->|"Send reset email"| SMTP

    %% ============================================================
    %% CONNECTIONS — In-Memory
    %% ============================================================
    VERIFY_ROUTES --> VERIFY_CODES
    AUTH_ROUTES --> RESET_TOKENS
    WHOOP_ROUTES --> PENDING_AUTH

    %% ============================================================
    %% CONNECTIONS — Internal modules
    %% ============================================================
    ROUTES --> AUTH_LAYER
    ROUTES --> DATA
    ROUTES --> MODELS
    ROUTES --> CONFIG
    WHOOP_ROUTES --> ENCRYPT

    %% ============================================================
    %% STYLING
    %% ============================================================
    classDef client fill:#1a1a2e,stroke:#E8475F,stroke-width:2px,color:#eee
    classDef server fill:#16213e,stroke:#4ade80,stroke-width:2px,color:#eee
    classDef storage fill:#0d1117,stroke:#fbbf24,stroke-width:2px,color:#eee
    classDef external fill:#1a0a2e,stroke:#818cf8,stroke-width:2px,color:#eee
    classDef memory fill:#1a1a0e,stroke:#f97316,stroke-width:1px,color:#eee
    classDef deploy fill:#0a1a1a,stroke:#06b6d4,stroke-width:1px,color:#eee

    class BROWSER,ADMIN client
    class LOGIN,REFRESH,FORGOT,RESET,GET_DATA,SAVE_DAY,SYNC_ALL,SAVE_WHOOP,GET_METRICS,SAVE_METRICS,LIST_USERS,GET_USER,SEND_VERIFY,DO_VERIFY,WHOOP_AUTH,WHOOP_CB,WHOOP_STATUS,WHOOP_DISC,WHOOP_SUMMARY,WHOOP_DETAIL,HEALTH server
    class USERS_JSON,USER_DATA,PROGRAM_JSON,EXERCISES_JSON,PROGRAM_CSV,WHOOP_TOKENS,WHOOP_CONFIG storage
    class WHOOP_API,SMTP external
    class VERIFY_CODES,RESET_TOKENS,PENDING_AUTH memory
    class PROCFILE,NIXPACKS,RUNTIME,REQUIREMENTS deploy
